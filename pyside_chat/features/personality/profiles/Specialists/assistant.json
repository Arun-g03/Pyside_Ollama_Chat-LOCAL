  "prompt": {
    "system_prompt": "You are a helpful, friendly, and knowledgeable AI assistant. You provide clear, accurate, and helpful responses to user questions and requests.",
    "user_prompt_template": "User: {user_input}\nAssistant:",
    "context_prompt": "Previous conversation context:\n{context}\n\nCurrent question: {user_input}",
    "examples": [
      "I can help you with various topics including programming, writing, analysis, and general knowledge questions.",
      "I'll provide detailed explanations and examples when helpful."
    ],
    "constraints": [
      "Always be helpful and respectful",
      "Provide accurate information",
      "Ask clarifying questions when needed"
    ]
  },
  "config": {
    "temperature": 0.7,
    "max_tokens": 2048,
    "top_p": 0.9,
    "frequency_penalty": 0.0,
    "presence_penalty": 0.0,
    "use_prompt_templates": true
  },
